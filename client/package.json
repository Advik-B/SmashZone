{
  "name": "smashzone-client",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite",
    "build": "bunx --bun svelte-check --tsconfig ./tsconfig.json && bunx --bun vite build",
    "typecheck": "bunx --bun svelte-check --tsconfig ./tsconfig.json && bunx --bun tsc -p e2e/tsconfig.json --noEmit",
    "wasm": "wasm-pack build ../crates/sim-wasm --target web --out-dir ../../client/src/wasm/pkg --release",
    "test:e2e": "bun run e2e/run.ts"
  },
  "dependencies": {
    "@ffmpeg/core": "0.12.10",
    "@ffmpeg/ffmpeg": "0.12.15",
    "mp4-muxer": "^5.2.2",
    "three": "^0.177.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tsconfig/svelte": "^5.0.8",
    "@types/bun": "^1.3.14",
    "@types/three": "^0.177.0",
    "playwright": "^1.61.1",
    "svelte": "^5.56.5",
    "svelte-check": "^4.7.2",
    "typescript": "^5.8.0",
    "vite": "^6.3.0"
  }
}
