{
  "name": "smashzone-client",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite",
    "build": "bunx --bun tsc --noEmit && bunx --bun vite build",
    "typecheck": "bunx --bun tsc --noEmit && bunx --bun tsc -p e2e/tsconfig.json --noEmit",
    "wasm": "wasm-pack build ../crates/sim-wasm --target web --out-dir ../../client/src/wasm/pkg --release",
    "test:e2e": "bun run e2e/run.ts"
  },
  "dependencies": {
    "three": "^0.177.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/three": "^0.177.0",
    "playwright": "^1.61.1",
    "typescript": "^5.8.0",
    "vite": "^6.3.0"
  }
}
